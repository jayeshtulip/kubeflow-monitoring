{
  "dashboard": {
    "title": "LLM Platform - Data Health",
    "uid": "llm-platform-data",
    "tags": [
      "llm-platform",
      "data"
    ],
    "timezone": "browser",
    "refresh": "1m",
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "Qdrant Pod Status",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "kube_pod_status_phase{namespace='llm-platform-prod', pod=~'qdrant.*', phase='Running'}",
            "legendFormat": "Qdrant"
          }
        ],
        "options": {
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": 0
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            },
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": {
                    "text": "DOWN"
                  },
                  "1": {
                    "text": "UP"
                  }
                }
              }
            ]
          }
        }
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Ollama Pod Status",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 0
        },
        "targets": [
          {
            "expr": "count(kube_pod_status_phase{namespace='llm-platform-prod', pod=~'ollama.*', phase='Running'})",
            "legendFormat": "Ollama"
          }
        ],
        "options": {
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": 0
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Redis Up",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "expr": "redis_up",
            "legendFormat": "Redis"
          }
        ],
        "options": {
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": 0
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            },
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": {
                    "text": "DOWN"
                  },
                  "1": {
                    "text": "UP"
                  }
                }
              }
            ]
          }
        }
      },
      {
        "id": 4,
        "type": "stat",
        "title": "PostgreSQL Up",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 0
        },
        "targets": [
          {
            "expr": "max(pg_up)",
            "legendFormat": "PostgreSQL"
          }
        ],
        "options": {
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": 0
                },
                {
                  "color": "green",
                  "value": 1
                }
              ]
            },
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": {
                    "text": "DOWN"
                  },
                  "1": {
                    "text": "UP"
                  }
                }
              }
            ]
          }
        }
      },
      {
        "id": 5,
        "type": "timeseries",
        "title": "Qdrant Pod CPU Usage",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 4
        },
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{namespace='llm-platform-prod', pod=~'qdrant.*', container!=''}[5m]))",
            "legendFormat": "Qdrant CPU"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "cores"
          }
        }
      },
      {
        "id": 6,
        "type": "timeseries",
        "title": "Qdrant Pod Memory",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 4
        },
        "targets": [
          {
            "expr": "sum(container_memory_working_set_bytes{namespace='llm-platform-prod', pod=~'qdrant.*', container!=''})",
            "legendFormat": "Qdrant Memory"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        }
      },
      {
        "id": 7,
        "type": "timeseries",
        "title": "Redis Hit Rate",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 12
        },
        "targets": [
          {
            "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m])) * 100",
            "legendFormat": "Hit Rate %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        }
      },
      {
        "id": 8,
        "type": "timeseries",
        "title": "Redis Memory Used vs Peak",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 12
        },
        "targets": [
          {
            "expr": "redis_memory_used_bytes",
            "legendFormat": "Used"
          },
          {
            "expr": "redis_memory_used_peak_bytes",
            "legendFormat": "Peak"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        }
      },
      {
        "id": 9,
        "type": "timeseries",
        "title": "All Platform Pods by Namespace",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 20
        },
        "targets": [
          {
            "expr": "count by (namespace) (kube_pod_status_phase{phase='Running'})",
            "legendFormat": "{{namespace}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      }
    ],
    "schemaVersion": 38,
    "version": 1
  },
  "overwrite": true,
  "folderId": 0
}